{
  "name": "highlight-line-vscode-fix",
  "displayName": "Highlight Line Fix",
  "description": "Highlights the current line in the editor. Find your location in your editor easily. Color & highlight style is completely customizable.",
  "version": "0.0.1",
  "publisher": "cliffordfajardo",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "highlight",
    "highlighter",
    "code highlighter",
    "line highlighter",
    "highlight line",
    "multi-root ready"
  ],
  "galleryBanner": {
    "color": "#232323",
    "theme": "dark"
  },
  "icon": "images/highlight-line-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cliffordfajardo/highlight-line-vscode"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension",
  "contributes": {
    "configuration": {
      "properties": {
        "highlightLine.borderColor": {
          "type": [
            "string"
          ],
          "default": "#65EAB9",
          "description": "Change the border color. (Ex: 'red', '#FFF', '#FFFFFF', 'RGB(255,255,255)', 'RGBA(255,255,255,0.5)')"
        },
        "highlightLine.borderWidth": {
          "type": [
            "string"
          ],
          "default": "2px"
        },
        "highlightLine.borderStyle": {
          "type": [
            "string"
          ],
          "enum": [
            "solid",
            "dashed",
            "inset",
            "double",
            "groove",
            "outset",
            "ridge"
          ],
          "default": "solid"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}